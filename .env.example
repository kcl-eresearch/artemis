# Environment variables for Artemis

# Required: Your SearXNG instance URL
SEARXNG_API_BASE=http://searxng:8080

# Recommended for production: require bearer auth on the API
ARTEMIS_API_KEY=replace-with-a-long-random-secret

# Comma-separated browser origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# LiteLLM-compatible endpoint for summarization
# Use your LiteLLM proxy or any OpenAI-compatible API
LITELLM_BASE_URL=http://localhost:11434/api

# API key for the LLM endpoint
# Can also use OPENAI_API_KEY
LITELLM_API_KEY=sk-your-key-here

# Model to use for summarization (default: qwen3.5:27b)
# Must be a valid model for your LITELLM_BASE_URL
SUMMARY_MODEL=qwen3.5:27b

# Deep research settings (static - configured via env, not per-request)
# Number of outline sections
DEEP_RESEARCH_STAGES=2
# Research passes - each refines queries
DEEP_RESEARCH_PASSES=1
# Queries per section per pass
DEEP_RESEARCH_SUBQUERIES=5
# Search results per subquery
DEEP_RESEARCH_RESULTS_PER_QUERY=10
# Max tokens for final essay
DEEP_RESEARCH_MAX_TOKENS=8000

# Content extraction - fetches full page text for richer synthesis
# Toggle page fetching on/off
DEEP_RESEARCH_CONTENT_EXTRACTION=true
# Top pages to extract per section
DEEP_RESEARCH_PAGES_PER_SECTION=3
# Max chars of extracted text per page
DEEP_RESEARCH_CONTENT_MAX_CHARS=3000

# Shallow research settings (static - configured via env, not per-request)
# Number of outline sections
SHALLOW_RESEARCH_STAGES=1
# Research passes
SHALLOW_RESEARCH_PASSES=1
# Queries per section per pass
SHALLOW_RESEARCH_SUBQUERIES=3
# Search results per subquery
SHALLOW_RESEARCH_RESULTS_PER_QUERY=5
# Max tokens for final essay
SHALLOW_RESEARCH_MAX_TOKENS=4000

# Shallow content extraction - typically disabled for faster responses
# Toggle page fetching on/off
SHALLOW_RESEARCH_CONTENT_EXTRACTION=false
# Top pages to extract per section
SHALLOW_RESEARCH_PAGES_PER_SECTION=2
# Max chars of extracted text per page
SHALLOW_RESEARCH_CONTENT_MAX_CHARS=2000

# Optional runtime settings
ENABLE_SUMMARY=true
SUMMARY_MAX_TOKENS=4000
SEARXNG_TIMEOUT_SECONDS=60
LLM_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
# Log format: "text" (human-readable) or "json" (structured, for production)
LOG_FORMAT=text

# Caching
CACHE_ENABLED=true
SEARCH_CACHE_TTL_SECONDS=3600
CONTENT_CACHE_TTL_SECONDS=86400
CACHE_MAX_ENTRIES=1000

# Semantic query deduplication (requires an embedding model)
# EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_SIMILARITY_THRESHOLD=0.92

# Playwright browser settings
PLAYWRIGHT_CONTEXT_RECYCLE_PAGES=50
PLAYWRIGHT_MAX_HTML_BYTES=5242880

# Agentic synthesis - live web_search tool calls during essay writing
# 0 = disabled (writes from pre-loaded results only)
SYNTHESIS_TOOL_ROUNDS=0

# Supervised research - hierarchical supervisor-researcher architecture
# Each outline section gets an autonomous agent with web_search, read_page, note tools
SUPERVISED_RESEARCH=false
RESEARCHER_MAX_TOOL_ROUNDS=15

# Research brief - refine raw queries into focused research questions before planning
RESEARCH_BRIEF_ENABLED=true

# Progressive summarization - distil each result's content before synthesis
# Controls token budget while preserving more signal than raw snippets
PROGRESSIVE_SUMMARIZATION=true
PROGRESSIVE_SUMMARY_MAX_CHARS=800
PROGRESSIVE_SUMMARY_MAX_TOKENS=500

# Researcher stopping heuristics (supervised mode only)
# Min pages with substantive content before a researcher may stop early
RESEARCHER_MIN_RELEVANT_SOURCES=3
# URL overlap ratio between last 2 searches that triggers early stopping
RESEARCHER_OVERLAP_THRESHOLD=0.6
